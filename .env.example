# Cascade Home Connect — environment variables
# Copy to .env.local and fill in. Never commit real secrets.

# Public canonical site URL (used for metadata, canonicals, sitemap).
NEXT_PUBLIC_SITE_URL=https://cascadehomeconnect.com

# Supabase project: cascade-home-connect (btifsnnjuiwpbwvlzstc, us-west-1)
# Server-side only — the service role bypasses RLS, keep secret. Copy the key from
# Dashboard > Project Settings > API keys. Lead intake persists when set; the form
# still works without it (logs a warning).
SUPABASE_URL=https://btifsnnjuiwpbwvlzstc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase keys (for the buyer portal / client auth — Phase 3).
NEXT_PUBLIC_SUPABASE_URL=https://btifsnnjuiwpbwvlzstc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_3tu-8RnLWiXo_YmOOvF9kQ_yGgoLOHf

# Optional: raises Census API rate limits (free key from api.census.gov). Enrichment
# works without it at our volume.
CENSUS_API_KEY=

# Cloudflare Turnstile (anti-bot on the quote form — Phase 1 follow-up).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
