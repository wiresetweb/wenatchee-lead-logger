# Cascade Home Connect — environment variables
# Copy to .env.local and fill in. Never commit real secrets.

# Public canonical site URL (used for metadata, canonicals, sitemap).
NEXT_PUBLIC_SITE_URL=https://cascadehomeconnect.com

# Supabase (server-side only — service role bypasses RLS, keep secret).
# Lead intake persists here when set; the form still works without it (logs a warning).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase keys (for the future buyer portal / client auth — Phase 3).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (anti-bot on the quote form — Phase 1 follow-up).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
